{
  "name": "sphynx-extension",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "npx tailwindcss -i src/popup/index.css -o public/dist/popup.css",
    "build:js": "node build.js",
    "build:prod": "node build.js --production",
    "build": "npm run build:css && npm run build:js",
    "build:production": "npm run build:css && npm run build:prod",
    "watch": "node build.js --watch",
    "icons": "node scripts/generate-icons.js"
  },
  "dependencies": {
    "framer-motion": "^12.4.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.298",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "esbuild": "^0.24.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  }
}
